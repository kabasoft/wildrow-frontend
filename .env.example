# Points the SPA at the deployed backend's public base path.
# Local dev (against `docker compose up` in wildrow-backend):
VITE_API_BASE_URL=http://localhost:8080/api

# Staging / production are set as Cloud Build substitutions baked in at
# build time (see cloudbuild.yaml) since this is a static SPA — there is no
# runtime server to read env vars from after the build.
